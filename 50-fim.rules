#############################################
# Linux File Integrity Monitoring (FIM)
# auditd ruleset – production grade
# Chronicle-compatible
#############################################

############################
# 0. Global audit settings
############################

# Remove any pre-existing rules
-D

# Increase buffers to avoid drops
-b 8192

# Panic if auditd fails (tamper resistance)
-f 1


#############################################
# 1. System binary integrity
#############################################

-w /bin        -p wa -k fim.bin
-w /sbin       -p wa -k fim.sbin
-w /usr/bin    -p wa -k fim.usrbin
-w /usr/sbin   -p wa -k fim.usrsbin


#############################################
# 2. Core system configuration
#############################################

-w /etc        -p wa -k fim.etc

# Identity & authentication
-w /etc/passwd  -p wa -k fim.identity
-w /etc/shadow  -p wa -k fim.identity
-w /etc/group   -p wa -k fim.identity
-w /etc/gshadow -p wa -k fim.identity

# Privilege escalation
-w /etc/sudoers    -p wa -k fim.sudo
-w /etc/sudoers.d  -p wa -k fim.sudo

# SSH hardening
-w /etc/ssh/sshd_config -p wa -k fim.ssh


#############################################
# 3. Persistence mechanisms
#############################################

# Cron jobs
-w /etc/cron.d       -p wa -k fim.cron
-w /etc/cron.daily  -p wa -k fim.cron
-w /etc/cron.hourly -p wa -k fim.cron
-w /etc/cron.weekly -p wa -k fim.cron
-w /etc/cron.monthly -p wa -k fim.cron
-w /var/spool/cron  -p wa -k fim.cron

# systemd services
-w /etc/systemd/system -p wa -k fim.systemd
-w /lib/systemd/system -p wa -k fim.systemd


#############################################
# 4. Boot & kernel integrity
#############################################

-w /boot        -p wa -k fim.boot
-w /lib/modules -p wa -k fim.kernel


#############################################
# 5. Atomic file replacement & deletion
#############################################

# Rename / unlink used for stealthy replacement
-a always,exit -F arch=b64 -S rename,renameat,unlink,unlinkat -k fim.delete
-a always,exit -F arch=b32 -S rename,renameat,unlink,unlinkat -k fim.delete


#############################################
# 6. Permission & ownership tampering
#############################################

-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat -k fim.perm
-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -k fim.owner


#############################################
# 7. Execution from suspicious locations
#############################################

-a always,exit -F arch=b64 -S execve -F dir=/tmp      -k exec.tmp
-a always,exit -F arch=b64 -S execve -F dir=/var/tmp -k exec.vartmp
-a always,exit -F arch=b64 -S execve -F dir=/dev/shm -k exec.shm


#############################################
# 8. Noise reduction (critical for prod)
#############################################

# Package managers
-a never,exit -F exe=/usr/bin/apt
-a never,exit -F exe=/usr/bin/apt-get
-a never,exit -F exe=/usr/bin/dpkg
-a never,exit -F exe=/usr/bin/yum
-a never,exit -F exe=/usr/bin/dnf
-a never,exit -F subj_type=rpm_t
# Cloud-init (one-time setup noise)
-a never,exit -F exe=/usr/bin/cloud-init
-a never,exit -F exe=/opt/puppetlabs/bin/puppet

#############################################
# 9. Lock ruleset (tamper protection)
#############################################

-e 2


