#############################################
# Linux Auditd – Low Noise FIM Profile
# Optimized for SIEM (Chronicle)
#############################################

############################
# 0. Global audit settings
############################

-D
-b 8192
-f 1


#############################################
# 1. Noise suppression (MUST come first)
#############################################

# Package managers (Debian/Ubuntu)
-a never,exit -F exe=/usr/bin/apt
-a never,exit -F exe=/usr/bin/apt-get
-a never,exit -F exe=/usr/bin/dpkg
## RHEL/Fedora – uncomment if present
#-a never,exit -F exe=/usr/bin/yum
#-a never,exit -F exe=/usr/bin/dnf
#-a never,exit -F subj_type=rpm_t

# Config mgmt / automation
-a never,exit -F exe=/usr/bin/cloud-init
-a never,exit -F exe=/usr/bin/ansible
## Uncomment if present
#-a never,exit -F exe=/opt/puppetlabs/bin/puppet

# Containers
-a never,exit -F exe=/usr/bin/dockerd
-a never,exit -F exe=/usr/bin/containerd
## Uncomment if present
#-a never,exit -F exe=/usr/bin/kubelet


#############################################
# 2. Critical identity & privilege config
#############################################

-w /etc/passwd      -p wa -k fim.identity
-w /etc/shadow      -p wa -k fim.identity
-w /etc/group       -p wa -k fim.identity
-w /etc/gshadow     -p wa -k fim.identity

-w /etc/sudoers     -p wa -k fim.sudo
-w /etc/sudoers.d   -p wa -k fim.sudo

-w /etc/ssh/sshd_config -p wa -k fim.ssh


#############################################
# 3. System binary integrity
#############################################

-w /usr/bin    -p wa -k fim.usrbin
-w /usr/sbin   -p wa -k fim.usrsbin


#############################################
# 4. Persistence mechanisms
#############################################

-w /etc/cron.d        -p wa -k fim.cron
-w /etc/cron.daily    -p wa -k fim.cron
-w /etc/cron.hourly   -p wa -k fim.cron
-w /etc/cron.weekly   -p wa -k fim.cron
-w /etc/cron.monthly  -p wa -k fim.cron
-w /var/spool/cron    -p wa -k fim.cron

-w /etc/systemd/system  -p wa -k fim.systemd
-w /lib/systemd/system  -p wa -k fim.systemd


#############################################
# 5. Boot & kernel integrity
#############################################

-w /boot        -p wa -k fim.boot
-w /lib/modules -p wa -k fim.kernel


#############################################
# 6. File deletion / replacement
#############################################

-a always,exit -F arch=b64 -S rename,renameat,unlink,unlinkat -F auid>=1000 -F auid!=4294967295 -k fim.delete
-a always,exit -F arch=b32 -S rename,renameat,unlink,unlinkat -F auid>=1000 -F auid!=4294967295 -k fim.delete


#############################################
# 7. Permission & ownership tampering
#############################################

-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=4294967295 -k fim.perm
-a always,exit -F arch=b32 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=4294967295 -k fim.perm
-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=4294967295 -k fim.owner
-a always,exit -F arch=b32 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=4294967295 -k fim.owner



#############################################
# 9. Suspicious execution (attack surface)
#############################################

-a always,exit -F arch=b64 -S execve -F dir=/tmp -F auid>=1000 -k exec.tmp
-a always,exit -F arch=b64 -S execve -F dir=/dev/shm -F auid>=1000 -k exec.shm
-a always,exit -F arch=b64 -S execve -F dir=/var/tmp -F auid>=1000 -k exec.vartmp


#############################################
# 10. Privilege escalation (runtime)
#############################################

-a always,exit -F arch=b64 -S execve -F euid=0 -F auid>=1000 -F auid!=4294967295 -k exec.priv_esc


#############################################
# 11. Lock ruleset
#############################################

-e 2
